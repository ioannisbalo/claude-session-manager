{
  "name": "claude-session-manager",
  "productName": "Claude Session Manager",
  "version": "1.0.0",
  "description": "Desktop app for managing multiple Claude Code CLI sessions",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc --build && npm run copy-assets",
    "copy-assets": "cp src/renderer/index.html dist/src/renderer/ && cp src/renderer/styles.css dist/src/renderer/",
    "start": "npm run build && electron .",
    "watch": "tsc -p tsconfig.json --watch & tsc -p tsconfig.renderer.json --watch",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.0.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
